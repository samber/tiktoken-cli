{
    "name": "tiktoken-cli",
    "version": "0.1.0",
    "description": "CLI for counting tokens in files and directories using tiktoken",
    "type": "module",
    "bin": {
        "tiktoken-cli": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm",
        "dev": "tsx src/index.ts"
    },
    "keywords": [
        "tiktoken",
        "tokens",
        "openai",
        "cli"
    ],
    "author": {
        "name": "Samuel Berthe",
        "email": "hey@samuel-berthe.fr",
        "url": "https://github.com/samber"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/samber/tiktoken-cli.git"
    },
    "homepage": "https://github.com/samber/tiktoken-cli",
    "bugs": {
        "url": "https://github.com/samber/tiktoken-cli/issues"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^25.3.5",
        "@types/yargs": "^17.0.0",
        "tsup": "^8.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "tiktoken": "^1.0.0",
        "yargs": "^17.0.0"
    }
}
